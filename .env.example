# Copy to .env (or set in your host's env) for production.

# Secret used to salt analytics visitor hashes (privacy). Set to a long random string.
FREMO_SECRET=change-me-to-a-long-random-string

# First-party API key the web client sends and the server requires on data routes.
# Rotate this to a random value so the gate header isn't a well-known default.
# NOTE: this is exposed to the browser (NEXT_PUBLIC_) — it's an anti-scrape gate,
# not a true secret. The real protections are rate-limiting + bot blocking.
NEXT_PUBLIC_FREMO_KEY=set-a-random-value-here
